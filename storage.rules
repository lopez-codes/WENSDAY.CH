rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User profile images - users can upload their own profile images
    match /users/{userId}/profile/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Conversation attachments - users can upload to their own conversations
    match /conversations/{conversationId}/attachments/{allPaths=**} {
      allow read, write: if request.auth != null && 
        isConversationOwner(conversationId);
    }

    // System assets - only admins can manage
    match /system/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // AI Provider assets - only admins can manage
    match /providers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    function isAdmin() {
      return request.auth != null && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isConversationOwner(conversationId) {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/conversations/$(conversationId)).data.userId == request.auth.uid;
    }
  }
}