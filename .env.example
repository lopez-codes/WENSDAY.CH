# Environment Variables for wensday.ch MVP
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/wensday"
PGHOST="localhost"
PGPORT="5432" 
PGUSER="user"
PGPASSWORD="password"
PGDATABASE="wensday"

# AI Provider API Keys
GEMINI_API_KEY="your_gemini_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
PERPLEXITY_API_KEY="your_perplexity_api_key_here"
XAI_API_KEY="your_xai_api_key_here"
AZURE_OPENAI_API_KEY="your_azure_openai_api_key_here"

# Payment Processing
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
POSTFINANCE_SHOP_ID="your_postfinance_shop_id"
POSTFINANCE_HMAC_KEY="your_postfinance_hmac_key"

# Firebase Configuration (for production deployment)
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_PRIVATE_KEY="your_firebase_private_key"
FIREBASE_CLIENT_EMAIL="your_firebase_client_email"

# Replit Authentication (for development)
REPLIT_CLIENT_ID="your_replit_client_id"
REPLIT_CLIENT_SECRET="your_replit_client_secret"

# Application Configuration
NODE_ENV="development"
SESSION_SECRET="your_session_secret_here"
ENCRYPTION_KEY="your_32_character_encryption_key"

# wensday-core Configuration
CORE_MASTER_KEY="your_wensday_core_master_key"
CORE_ENCRYPTION_SALT="your_core_encryption_salt"

# Swiss Business Configuration
COMPANY_UID="CHE-316.025.450"
COMPANY_NAME="Lopez Codes"
SUPPORT_EMAIL="dev.n.lopez@gmail.com"
ADMIN_EMAIL="dev.n.lopez@gmail.com"